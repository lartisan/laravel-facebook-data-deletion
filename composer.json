{
    "name": "lartisan/laravel-facebook-data-deletion",
    "description": "A reusable Laravel package for handling Meta/Facebook user data deletion callbacks.",
    "keywords": [
        "facebook",
        "meta",
        "laravel",
        "data deletion",
        "privacy"
    ],
    "license": "MIT",
    "type": "library",
    "authors": [
        {
            "name": "Cristian Iosif",
            "email": "cristianiosif@me.com"
        }
    ],
    "require": {
        "php": "^8.2",
        "illuminate/contracts": "^11.0|^12.0",
        "illuminate/database": "^11.0|^12.0",
        "illuminate/http": "^11.0|^12.0",
        "illuminate/queue": "^11.0|^12.0",
        "illuminate/routing": "^11.0|^12.0",
        "illuminate/support": "^11.0|^12.0",
        "illuminate/view": "^11.0|^12.0"
    },
    "require-dev": {
        "mockery/mockery": "^1.6",
        "orchestra/testbench": "^9.0|^10.0",
        "pestphp/pest": "^3.0"
    },
    "autoload": {
        "psr-4": {
            "Lartisan\\FacebookDataDeletion\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Lartisan\\FacebookDataDeletion\\Tests\\": "tests/"
        }
    },
    "extra": {
        "laravel": {
            "providers": [
                "Lartisan\\FacebookDataDeletion\\FacebookDataDeletionServiceProvider"
            ]
        }
    },
    "scripts": {
        "test": "./vendor/bin/pest"
    },
    "config": {
        "sort-packages": true,
        "allow-plugins": {
            "pestphp/pest-plugin": true
        }
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}

